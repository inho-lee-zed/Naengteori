{
  "expo": {
    "name": "naengteori",
    "slug": "naengteori",
    "scheme": "naengteori",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.naengteori.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "냉장고 사진을 촬영하여 재료를 인식합니다",
        "NSPhotoLibraryUsageDescription": "냉장고 사진을 선택하여 재료를 인식합니다"
      }
    },
    "android": {
      "package": "com.naengteori.app",
      "versionCode": 1,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "냉장고 사진을 촬영하여 재료를 인식합니다",
          "microphonePermission": false,
          "recordAudioAndroid": false
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "냉장고 사진을 선택하여 재료를 인식합니다",
          "cameraPermission": "냉장고 사진을 촬영하여 재료를 인식합니다"
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "eac37662-975f-4d78-88ea-bd6722bfa4cd"
      }
    }
  }
}
